{
  "name": "sites-relay",
  "version": "0.1.0",
  "description": "A policy-constrained, fixed-upstream relay for ChatGPT Sites, with JSON/SSE streaming and an optional sanitized static web mirror.",
  "private": true,
  "license": "MIT",
  "homepage": "https://github.com/FogMoe/chatgpt-sites-relay#readme",
  "bugs": {
    "url": "https://github.com/FogMoe/chatgpt-sites-relay/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FogMoe/chatgpt-sites-relay.git"
  },
  "keywords": [
    "api-relay",
    "chatgpt-sites",
    "json-api",
    "server-sent-events",
    "static-web-mirror"
  ],
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vinext dev",
    "build": "vinext build",
    "start": "vinext start",
    "test": "npm run build && node --test tests/rendered-html.test.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next"
  },
  "dependencies": {
    "next": "16.2.11",
    "parse5": "8.0.1",
    "postcss": "8.5.14",
    "postcss-value-parser": "4.2.0",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.14",
      "sharp": "0.35.0"
    }
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.47.0",
    "@cloudflare/workers-types": "5.20260723.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.1.5",
    "wrangler": "4.114.0"
  },
  "type": "module"
}
