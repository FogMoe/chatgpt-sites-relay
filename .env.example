# Required: one HTTPS origin using a DNS hostname. Do not include a path or credentials.
PROXY_UPSTREAM_ORIGIN=https://api.example.com

# Required: a random 32–256 character base64url value. Generate one with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
PROXY_ACCESS_TOKEN=

# Required: comma-separated METHOD:/path rules. Use METHOD:/ only after reviewing the full upstream surface.
PROXY_ALLOWED_ROUTES=GET:/v1/models,POST:/v1/responses

# Optional: exact query parameter names allowed upstream. Empty means no query parameters.
PROXY_ALLOWED_QUERY_KEYS=

# Optional: exact browser origins allowed to call the proxy, comma-separated.
PROXY_ALLOWED_ORIGINS=https://your-app.example

# Optional: server-side Authorization value injected into upstream requests.
PROXY_UPSTREAM_AUTHORIZATION=

# Optional: expose a read-only static mirror of the same fixed upstream at /web/*.
WEB_RELAY_ENABLED=false

# Required when the static mirror is enabled: comma-separated upstream path prefixes.
WEB_RELAY_ALLOWED_PATH_PREFIXES=

# Optional: exact query parameter names allowed through the static mirror.
WEB_RELAY_ALLOWED_QUERY_KEYS=
